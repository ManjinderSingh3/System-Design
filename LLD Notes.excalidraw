    {
      "id": "_QhQ-rA4cNiMKSTsGVtjd",
      "type": "text",
      "x": 4084.24081475767,
      "y": 45.843083387750085,
      "width": 438.3279138594798,
      "height": 238.78004668793227,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "az",
      "roundness": null,
      "seed": 169960579,
      "version": 294,
      "versionNonce": 537649293,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1755262432224,
      "link": null,
      "locked": false,
      "text": "public final class Singleton {\n    private static volatile Singleton instance;\n\n    private Singleton() {}\n\n    public static Singleton getInstance(String value) {\n        if (instance == null) {\n            synchronized (Singleton.class) {\n                if (instance == null) {\n                    instance = new Singleton();\n                }\n            }\n        }\n        return instance;\n    }\n}",
      "fontSize": 11.9390023343966,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public final class Singleton {\n    private static volatile Singleton instance;\n\n    private Singleton() {}\n\n    public static Singleton getInstance(String value) {\n        if (instance == null) {\n            synchronized (Singleton.class) {\n                if (instance == null) {\n                    instance = new Singleton();\n                }\n            }\n        }\n        return instance;\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
