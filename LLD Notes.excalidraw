      "updated": 1755262432224,
      "link": null,
      "locked": false,
      "text": "Define one to many relations b/w the object so that when one\nobject changes state, all it's dependents are notified. ",
      "fontSize": 18.03162141473083,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Define one to many relations b/w the object so that when one\nobject changes state, all it's dependents are notified. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
