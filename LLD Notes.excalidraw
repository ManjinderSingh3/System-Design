    {
      "type": "text",
      "version": 1073,
      "versionNonce": 1092408910,
      "index": "aC",
      "isDeleted": false,
      "id": "hbJtVlzAaCuJ5bpq0bTZO",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 444.9053261024337,
      "y": -323.0451483945144,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "width": 565.068359375,
